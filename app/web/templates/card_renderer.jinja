{% extends "scaffold.jinja" %}

{% block content %}
  <h1 class="title">Card Renderer</h1>
  <form id="renderer-form" action="/card_renderer" method="post">
    <fieldset class="field is-grouped">
      <div>
        <label class="label">Input Adapter</label>
        <div class="control">
          <div class="select">
            <select name="input_adapter">
              {% for input_adapter in input_adapters %}
                <option value="{{ input_adapter.get_display_name() }}">{{ input_adapter.get_display_name() }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      </div>
      <div>
        <label class="label">Process Adapter</label>
        <div class="control">
          <div class="select">
            <select name="process_adapter">
              {% for process_adapter in process_adapters %}
                <option value="{{ process_adapter.get_display_name() }}">{{ process_adapter.get_display_name() }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      </div>
      <div>
        <label class="label">Output Adapter</label>
        <div class="control">
          <div class="select">
            <select name="output_adapter">
              {% for output_adapter in output_adapters %}
                <option value="{{ output_adapter.get_display_name() }}">{{ output_adapter.get_display_name() }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      </div>
    </fieldset>
    <fieldset class="field">
        <label class="label">Card IDs (comma-separated)</label>
        <div class="control">
            <input class="input" type="text" name="card_ids" placeholder="1,2,3">
        </div>
    </fieldset>
    <fieldset class="field">
        <label class="label">Release Label</label>
        <div class="control">
            <input class="input" type="text" name="release_label" placeholder="α" value="α">
        </div>
    </fieldset>
    <hr />
    <fieldset class="field">
        <div class="control">
            <label class="checkbox">
                <input type="checkbox" name="commit_to_repo" value="true">
                Commit cards to repository
            </label>
        </div>
    </fieldset>
    <fieldset class="field">
        <label class="label">Internal Edition Label</label>
        <div class="control">
            <input id="repo-export-folder" class="input" type="text" name="internal_edition_label" placeholder="folder_name" value="dev">
        </div>
    </fieldset>
    <script>
        (function() {
            const checkbox = document.querySelector('input[name="commit_to_repo"]');
            const input = document.getElementById('repo-export-folder');
            const updateState = function() {
                input.disabled = !checkbox.checked;
            };
            checkbox.addEventListener('change', updateState);
            updateState();
        })();
    </script>
    <fieldset class="field mt-5">
      <div class="control">
        <button id="submit-btn" class="button is-primary" type="submit">Submit</button>
      </div>
      <p id="error-message" class="help is-danger" style="display: none;"></p>
    </fieldset>
  </form>

  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

  <script>
      document.getElementById('renderer-form').addEventListener('submit', function(e) {
          e.preventDefault(); // Stop the browser from navigating away

          const form = this;
          const btn = document.getElementById('submit-btn');
          const errorMsg = document.getElementById('error-message');

          // 1. UI Feedback: Set loading state and clear errors
          btn.classList.add('is-loading');
          btn.disabled = true;
          errorMsg.style.display = 'none';
          errorMsg.innerText = '';

          // 2. Prepare Data
          const formData = new FormData(form);

          // 3. Make the Request
          axios.post('/card_renderer', formData, {
                  responseType: 'blob', // IMPORTANT: Tells Axios to handle binary data
                  timeout: 600000 // Timeout in ms (e.g., 600000 = 10 minutes)
              })
              .then(function(response) {
                  // 4. Handle Success: Trigger Download

                  // Create a URL for the blob
                  const url = window.URL.createObjectURL(new Blob([response.data]));
                  const link = document.createElement('a');
                  link.href = url;

                  // Try to get filename from headers, otherwise default
                  const contentDisposition = response.headers['content-disposition'];
                  let fileName = 'data.zip';
                  if (contentDisposition) {
                      const fileNameMatch = contentDisposition.match(/filename="?([^"]+)"?/);
                      if (fileNameMatch && fileNameMatch.length === 2)
                          fileName = fileNameMatch[1];
                  }

                  link.setAttribute('download', fileName);
                  document.body.appendChild(link);
                  link.click();

                  // Cleanup
                  link.remove();
                  window.URL.revokeObjectURL(url);
              })
              .catch(function(error) {
                  // 5. Handle Errors
                  console.error(error);
                  errorMsg.style.display = 'block';

                  if (error.code === 'ECONNABORTED') {
                      errorMsg.innerText = 'The request timed out. The server is taking too long to respond.';
                  } else if (error.response) {
                      // Server responded with a status other than 2xx
                      // Note: Since responseType is blob, we might need to read the blob text to see the error message
                      errorMsg.innerText = `Error: ${error.response.statusText}`;
                  } else {
                      errorMsg.innerText = 'An unexpected error occurred.';
                  }
              })
              .finally(function() {
                  // 6. Reset UI State
                  btn.classList.remove('is-loading');
                  btn.disabled = false;
              });
      });
  </script>
{% endblock %}
