<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title is defined %}{{ title }}{% else %}TCG Maker 2{% endif %}</title>
    <link rel="stylesheet" href="static/css/bulma.min.css">
</head>

<body>
    <header>
        <nav class="navbar" role="navigation" aria-label="main navigation">
            <div class="navbar-brand">
                <a class="navbar-item" href="/">
                    <h1 class="title">{% if title is defined %}{{ title }}{% else %}TCG Maker 2{% endif %}</h1>
                </a>
                <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="mainNavBar">
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                </a>
            </div>
            <div id="mainNavBar" class="navbar-menu">
                <div class="navbar-start">
                    <a class="navbar-item" href="/card_renderer">
                        Renderer
                    </a>
                </div>
            </div>
        </nav>
    </header>
    <main>
        <section class="section">
            <div class="container">
                {% block content %}{% endblock %}
            </div>
        </section>
    </main>
    <footer>
        <p class="has-text-centered">&copy; {{ now.year }} by {% if author is defined %}{{ author }}{% else %}Aetherlab{% endif %}</p>
    </footer>
    <script src="static/js/bulma.js"></script>
</body>

</html>